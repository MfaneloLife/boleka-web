###############################################
# Boleka Web Example Environment File
# Copy -> .env.local for local development.
# Never commit real secrets. Configure these in Vercel
# (Project Settings > Environment Variables) for
# Development / Preview / Production.
###############################################

############################
# ✅ NEON PostgreSQL Database (REQUIRED)
############################
# Get your Neon connection string from https://console.neon.tech/
# Format: postgresql://user:password@host/database_name?sslmode=require
DATABASE_URL=postgresql://user:password@host.neon.tech/boleka_db?sslmode=require

############################
# Clerk Authentication (REQUIRED)
############################
# Get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/profile-setup

############################
# App URLs
############################
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production set this to your Vercel domain
# NEXT_PUBLIC_APP_URL=https://boleka-web.vercel.app

############################
# PayFast (Payment Processing)
############################
PAYFAST_MERCHANT_ID=17739107
PAYFAST_MERCHANT_KEY=m2hpqzhb9yvsr
PAYFAST_PASS_PHRASE=

############################
# Cloudflare R2 (Image Storage)
############################
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_PUBLIC_URL=
R2_ENDPOINT=

############################
# Optional: Email Provider
############################
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@your-domain

############################
# Optional: Google Cloud Vision
############################
GOOGLE_APPLICATION_CREDENTIALS=

############################
# Optional: FCM (Firebase Cloud Messaging)
############################
NEXT_PUBLIC_FCM_VAPID_KEY=

############################
# Misc
############################
# Disable GCP metadata probing (prevents noisy warnings on Vercel)
GCE_METADATA_HOST=disabled
