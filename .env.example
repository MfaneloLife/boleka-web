###############################################
# Boleka Web Example Environment File
# Copy -> .env.local for local development.
# Never commit real secrets. Configure these in Vercel
# (Project Settings > Environment Variables) for
# Development / Preview / Production.
###############################################

############################
# ✅ NEON PostgreSQL Database (REQUIRED for Boleka v2)
############################
# Get your Neon connection string from https://console.neon.tech/
# Format: postgresql://user:password@host/database_name?sslmode=require
DATABASE_URL=postgresql://user:password@host.neon.tech/boleka_db?sslmode=require

############################
# NextAuth Core (REQUIRED)
############################
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_strong_random_secret
NEXTAUTH_URL=http://localhost:3000
# In production set this to your canonical domain
# NEXTAUTH_URL=https://app.boleka.com

############################
# Email Provider (optional)
############################
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@your-domain

############################
# OAuth Providers (optional)
############################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

############################
# Firebase (Client SDK - public)
#########
# Notes:
# 1. After adding/updating env vars in Vercel, re-deploy.
# 2. Preview & Production envs are isolated; set both.
# 3. Remove any default hard-coded fallback keys in code
#    before going live (replace with environment values).
# 4. Keep private keys out of client bundles by avoiding
#    NEXT_PUBLIC_ prefix for sensitive vars.
###############################################
