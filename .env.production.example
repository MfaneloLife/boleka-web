# ===================================================================
# Production Environment Variables (.env.production.example)
# Use these as a reference when configuring Vercel project settings.
# NEVER commit a real .env.production file with secrets.
# ===================================================================

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/profile-setup

# --- Database (Neon/PostgreSQL) ---
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://your-vercel-deployment-url.vercel.app

# --- PayFast ---
PAYFAST_MERCHANT_ID=17739107
PAYFAST_MERCHANT_KEY=m2hpqzhb9yvsr
PAYFAST_PASS_PHRASE=

# --- Google Cloud Vision (optional) ---
GOOGLE_APPLICATION_CREDENTIALS=

# --- FCM (optional, for notifications) ---
NEXT_PUBLIC_FCM_VAPID_KEY=

# --- Disable GCP metadata probing (prevents noisy warnings on Vercel) ---
GCE_METADATA_HOST=disabled

# --- Runtime ---
NODE_ENV=production
