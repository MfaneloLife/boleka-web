# ===================================================================
# Production Environment Variables (.env.production.example)
# Use these as a reference when configuring Vercel project settings.
# NEVER commit a real .env.production file with secrets.
# ===================================================================

# --- Public (Client) Firebase Config ---
# Disable GCP metadata probing (prevents noisy MetadataLookupWarning on Vercel)
GCE_METADATA_HOST=disabled

# --- Auth ---
NEXTAUTH_URL=https://your-vercel-deployment-url.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXT_PUBLIC_APP_URL=https://your-vercel-deployment-url.vercel.app

# --- Database ---
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/prod.db

# --- Logging (optional) ---
# FORCE_LOG_LEVEL=debug

# --- Runtime ---
NODE_ENV=production
